# Version control
.git/
.gitignore

# Python caches
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# Testing & linting caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Environment (secrets — never bake into images)
.env

# Data (mounted as volume, not baked in)
data/

# Documentation (not needed at runtime)
docs/
*.md
!README.md
LICENSE

# Claude config
.claude/
CLAUDE.md
