# Financial Modeling Prep — primary data source for financials & universe
# Free tier available at https://financialmodelingprep.com/
# Optional: yfinance fallback handles most data without this key
FMP_API_KEY=your_key_here

# FRED (Federal Reserve Economic Data) — macro indicators
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
# Recommended: provides accurate bond yields for valuation
FRED_API_KEY=your_key_here

# Anthropic — optional LLM-assisted qualitative moat assessment
# Get a key at https://console.anthropic.com/
# Optional: run with --no-moat to skip
ANTHROPIC_API_KEY=your_key_here

# SEC EDGAR — optional fallback for financial filings
# Format: "FirstName LastName email@example.com"
# SEC_USER_AGENT=YourName contact@example.com
